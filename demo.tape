# peasy-audio-rs — Audio trim, merge, convert (Rust)
# Theme: Rose Pine
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "rose-pine"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasy-audio-rs — Audio trim, merge, convert for Rust"
Enter
Type "# peasyaudio.com"
Enter
Sleep 500ms

# Run the demo
Type "cargo run --example demo 2>/dev/null"
Enter
Sleep 5s
